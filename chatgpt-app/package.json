{
  "name": "nearnow-chatgpt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "esbuild web/src/widget.ts --bundle --format=esm --outfile=web/dist/widget.js",
    "dev": "tsx watch server/src/index.ts",
    "start": "node server/dist/index.js",
    "typecheck": "tsc -p web/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.2"
  }
}
