# PostgreSQL connection string. Local Docker default below.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://menrush:menrush123@localhost:5432/menrush

# JWT signing secret. Generate with: openssl rand -base64 64
# MUST be changed for production. Server refuses to start if unset.
JWT_SECRET=change-me-to-a-long-random-string

# CORS + Socket.IO origin allowlist. Comma-separated for multiple origins.
FRONTEND_URL=http://localhost:5173

# HTTP port the Express server binds to.
PORT=3000

# 'development' | 'production'. Affects logging and helmet defaults.
NODE_ENV=development

# Web Push (VAPID) keys. Generate with: npx web-push generate-vapid-keys
# Used for browser push notifications on new messages/matches.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact email or URL for the VAPID subject (mailto:you@example.com).
VAPID_EMAIL=mailto:admin@menrush.com

# Stripe Identity verification. Get keys at https://dashboard.stripe.com/apikeys
# Webhook signing secret comes from the dashboard webhook endpoint config or
# `stripe listen --forward-to localhost:3000/api/verify/webhook` for local dev.
STRIPE_SECRET_KEY=sk_test___SET_ME__
STRIPE_WEBHOOK_SECRET=whsec___SET_ME__

# ─── Zoho Mail SMTP (contact form → privacy@menrush.com) ─────────────────────
# Create an app-specific password in Zoho Mail → Security → App passwords.
# https://www.zoho.com/mail/help/zoho-smtp.html
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
# Set to true only when using port 465 with implicit TLS.
ZOHO_SMTP_SECURE=false
ZOHO_SMTP_USER=notifications@menrush.com
ZOHO_SMTP_PASS=
# Inbox for contact submissions (default: privacy@menrush.com).
CONTACT_TO_EMAIL=privacy@menrush.com
# From address (must be an allowed sender in Zoho; often same as ZOHO_SMTP_USER).
CONTACT_FROM_EMAIL=
# Optional generic from address override used by other mail senders (drip).
# Falls back to CONTACT_FROM_EMAIL, then ZOHO_SMTP_USER.
MAIL_FROM_EMAIL=

# ─── Waitlist drip campaign ──────────────────────────────────────────────────
# See docs/self-hosted-drip.md for the full operating guide.
# Public base URL used in unsubscribe links emitted by drip emails.
# Should be the public API origin (e.g. https://api.menrush.com).
PUBLIC_API_URL=
# Long random string. Required to call /api/waitlist/admin/run from a cron.
# Generate with: openssl rand -hex 32
DRIP_ADMIN_TOKEN=
# Set to 'true' to run an in-process drip worker on the backend itself.
# Leave unset / 'false' in production when an external cron will hit
# POST /api/waitlist/admin/run on a schedule instead.
DRIP_WORKER_ENABLED=false
# When DRIP_WORKER_ENABLED=true, how often to poll for due sends.
DRIP_WORKER_INTERVAL_MINUTES=60
