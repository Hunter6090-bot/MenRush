# PostgreSQL connection string. Local Docker default below.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://menrush:menrush123@localhost:5432/menrush

# JWT signing secret. Generate with: openssl rand -base64 64
# MUST be changed for production. Server refuses to start if unset.
JWT_SECRET=change-me-to-a-long-random-string

# CORS + Socket.IO origin allowlist. Comma-separated for multiple origins.
FRONTEND_URL=http://localhost:5173

# HTTP port the Express server binds to.
PORT=3000

# 'development' | 'production'. Affects logging and helmet defaults.
NODE_ENV=development

# Local testing only: skip ID verification and mark new signups verified.
# Never enable in production.
DEV_AUTO_VERIFY=false

# Web Push (VAPID) keys. Generate with: npx web-push generate-vapid-keys
# Used for browser push notifications on new messages/matches.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact email or URL for the VAPID subject (mailto:you@example.com).
VAPID_EMAIL=mailto:admin@menrush.com

# HMAC pepper for one-way document fingerprints (dedup). Falls back to JWT_SECRET if unset.
# Generate with: openssl rand -hex 32
VERIFICATION_DEDUP_PEPPER=

# Native ID + selfie verification
# Auto-approve when face match passes (set false to require manual admin review for all)
VERIFICATION_AUTO_APPROVE=true
# Face match distance thresholds (lower distance = closer match). Default pass 0.55, reject 0.65.
# VERIFICATION_FACE_PASS_THRESHOLD=0.55
# VERIFICATION_FACE_REJECT_THRESHOLD=0.65

# ─── CCBill Premium billing (FlexForms + webhooks) ───────────────────────────
# Get credentials after merchant approval: https://ccbill.com
CCBILL_FLEXFORM_ID=
CCBILL_CLIENT_SUBACC=
CCBILL_FORM_DIGEST_SALT=
# Optional: defaults to https://api.ccbill.com/wap-frontflex/flexforms/{CCBILL_FLEXFORM_ID}
# CCBILL_FLEXFORM_BASE_URL=
# CCBILL_CURRENCY_CODE=826
# CCBILL_WEBHOOK_SECRET=
# CCBILL_PREMIUM_INITIAL_PRICE=4.99
# CCBILL_PREMIUM_RECURRING_PRICE=4.99

# ─── Zoho Mail SMTP (contact form → privacy@menrush.com) ─────────────────────
# Create an app-specific password in Zoho Mail → Security → App passwords.
# https://www.zoho.com/mail/help/zoho-smtp.html
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
# Set to true only when using port 465 with implicit TLS.
ZOHO_SMTP_SECURE=false
ZOHO_SMTP_USER=notifications@menrush.com
ZOHO_SMTP_PASS=
# Inbox for contact submissions (default: privacy@menrush.com).
CONTACT_TO_EMAIL=privacy@menrush.com
# From address (must be an allowed sender in Zoho; often same as ZOHO_SMTP_USER).
CONTACT_FROM_EMAIL=

# ─── Resend (transactional mail — admin smoke test; product flows later) ───
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=hello@send.menrush.com
RESEND_REPLY_TO=hello@menrush.com
# Protects POST /api/admin/test-email. Generate with: openssl rand -hex 32
ADMIN_TOKEN=<generate with: openssl rand -hex 32>

# ─── WebRTC / video calls ────────────────────────────────────────────────────
# STUN is always enabled. For calls across different Wi‑Fi / mobile networks,
# configure your own TURN server (recommended for production). When unset, a
# public relay fallback is used for development.
# TURN_URL=turn:turn.example.com:3478,turns:turn.example.com:5349
# TURN_USERNAME=
# TURN_CREDENTIAL=

# ─── Error reporting (optional; no-op when SENTRY_DSN is unset) ────────────
# Request bodies, query strings, cookies, auth headers, user identity and
# breadcrumbs are stripped before events are sent. Performance tracing is off.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
