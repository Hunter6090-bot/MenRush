# Backend API base URL. Use /api for LAN/mobile testing (Vite proxies to localhost:3000).
VITE_API_URL=/api

# Leave empty so Socket.IO and uploads use the page origin (works on phone via LAN IP).
# Set only when the API runs on a different host than the Vite dev server.
VITE_SOCKET_URL=

# Mapbox access token for the discovery map.
# Get one at: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_token_here

# Public app URL encoded in profile QR codes (HTTPS tunnel or production domain).
# Example: https://your-app.trycloudflare.com or https://menrush.com
VITE_PUBLIC_APP_URL=

# Feature toggles — set to 'true' to enable WebRTC calling and Rooms in the shell.
VITE_FEATURE_VIDEO=false
VITE_FEATURE_ROOMS=false

# Closed beta: users must enter an invite code at /beta before /register.
# Set to true on Vercel production during beta.
VITE_BETA_INVITE_REQUIRED=false

# Optional production observability. Both integrations no-op when unset.
# Statsig uses a public client key and anonymous per-session IDs only.
VITE_STATSIG_CLIENT_KEY=
# Sentry DSNs are public routing identifiers, not secret auth tokens.
VITE_SENTRY_DSN=
VITE_APP_ENV=development
VITE_APP_RELEASE=
