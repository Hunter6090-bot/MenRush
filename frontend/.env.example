# Backend API base URL (axios). Include /api suffix in code, not here.
VITE_API_URL=http://localhost:3000

# Socket.IO server URL. Usually same host as VITE_API_URL.
VITE_SOCKET_URL=http://localhost:3000

# Mapbox access token for the discovery map.
# Get one at: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_token_here

# Stripe publishable key for Stripe Identity hosted verification flow.
# Server-side secret keys live in backend/.env, never here.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test___SET_ME__

# Feature toggles — set to 'true' to enable WebRTC calling and Rooms in the shell.
VITE_FEATURE_VIDEO=false
VITE_FEATURE_ROOMS=false

# Optional production observability. Both integrations no-op when unset.
# Statsig uses a public client key and anonymous per-session IDs only.
VITE_STATSIG_CLIENT_KEY=
# Sentry DSNs are public routing identifiers, not secret auth tokens.
VITE_SENTRY_DSN=
VITE_APP_ENV=development
VITE_APP_RELEASE=
