# ─── Database ──────────────────────────────────────────
# For docker-compose: use 'postgres' as hostname
# For local dev outside Docker: use 'localhost'
DATABASE_URL=postgresql://menrush:menrush123@postgres:5432/menrush

# ─── Auth ──────────────────────────────────────────────
# CHANGE THIS in production — use a long random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS / Frontend ───────────────────────────────────
# Set to your frontend origin (used for CORS and Socket.IO)
FRONTEND_URL=http://localhost:5173

# ─── Frontend (Vite) ───────────────────────────────────
# Used by the Vite frontend to reach the backend API
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_FEATURE_VIDEO=false
VITE_FEATURE_ROOMS=false
